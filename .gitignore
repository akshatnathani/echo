# Build outputs
dist/
build/
.vite/
*.tsbuildinfo

# IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
coverage/
.nyc_output/

# Logs
logs/
*.log

# OS
Thumbs.db
.DS_Store

# Temporary files
*.tmp
*.temp
.cache/

# MongoDB
data/

# Client specific
client/.env.production
client/dist-ssr

# Server specific
server/.env.production
server/uploads/
